{
  "manifest_version": 3,
  "name": "Paper Scorecard",
  "description": "AI reviewer scorecards for arXiv papers, using configurable API settings and an evidence-driven review rubric.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["https://arxiv.org/*", "<all_urls>"],
  "background": {
    "scripts": ["src/background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://arxiv.org/abs/*", "https://arxiv.org/pdf/*"],
      "js": ["src/review-renderer.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "sidebar_action": {
    "default_title": "Paper Scorecard",
    "default_panel": "src/sidepanel.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Paper Scorecard",
    "default_popup": "src/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["vendor/pdfjs/pdf.worker.min.mjs"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "paper-scorecard@example.local"
    }
  }
}
